rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // CrewRoster Security Rules — Firebase Auth
    //
    // The app uses Firebase Auth for authentication
    // and Firestore Web SDK for direct data access.
    // No backend server required.
    // ──────────────────────────────────────────────

    // ── USERS ────────────────────────────────────
    match /users/{userId} {
      // Owner can read their own profile
      allow get: if request.auth != null
                  && request.auth.uid == userId;

      // Owner can create their profile on registration
      // Only allow expected fields
      allow create: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.crewCode is string
                     && request.resource.data.fullName is string
                     && request.resource.data.keys().hasOnly([
                          'crewCode', 'fullName', 'base', 'role',
                          'email', 'phone', 'medicalValidity', 'lpcValidity',
                          'createdAt', 'updatedAt'
                        ]);

      // Owner can update email, phone only
      allow update: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['email', 'phone', 'updatedAt']);

      // No listing users
      allow list: if false;
      allow delete: if false;
    }

    // ── DUTIES ───────────────────────────────────
    match /duties/{dutyId} {
      // Owner can read their own duties
      allow read: if request.auth != null
                   && resource.data.userId == request.auth.uid;

      // Owner can create duties (via import)
      allow create: if request.auth != null
                     && request.resource.data.userId == request.auth.uid;

      // Owner can update duties (via import)
      allow update: if request.auth != null
                     && resource.data.userId == request.auth.uid;

      // Owner can delete their duties
      allow delete: if request.auth != null
                     && resource.data.userId == request.auth.uid;
    }

    // ── FLIGHTS ──────────────────────────────────
    match /flights/{flightId} {
      // Any authenticated user can read flights (shared reference)
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── NOTIFICATIONS ────────────────────────────
    match /notifications/{notifId} {
      // Owner can read their own notifications
      allow read: if request.auth != null
                   && resource.data.userId == request.auth.uid;

      // Notifications are created by import logic
      allow create: if request.auth != null
                     && request.resource.data.userId == request.auth.uid;

      // Owner can mark as read only
      allow update: if request.auth != null
                     && resource.data.userId == request.auth.uid
                     && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['isRead']);

      allow delete: if false;
    }
  }
}
