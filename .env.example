# CrewRoster Environment Configuration - Firebase
# Copy this file to .env and customize the values

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=change-this-to-a-random-secret-at-least-64-chars
JWT_REFRESH_SECRET=change-this-to-another-random-secret

# Application URL (Firebase deployment)
APP_URL=https://us-central1-crewroster-app.cloudfunctions.net/api

# For local development with Firebase Emulators:
# FIRESTORE_EMULATOR_HOST=localhost:8080

# For production:
# GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json
